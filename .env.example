# ── Backend (backend/.env) ──────────────────────────────────────────
PORT=3000
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# LiveKit (Cloud now; swap LIVEKIT_URL for self-host later)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=raphael-buddy

# Shared secret between agent worker and Hono internal routes
INTERNAL_API_KEY=change-me-in-production

# ── Agent worker (agent/.env.local) ─────────────────────────────────
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=          # US casual preset from ElevenLabs dashboard
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# BACKEND_URL=http://localhost:3000
# INTERNAL_API_KEY=             # must match backend

